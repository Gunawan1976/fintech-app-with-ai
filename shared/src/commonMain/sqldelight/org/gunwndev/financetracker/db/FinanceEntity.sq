CREATE TABLE FinanceEntity (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    category TEXT NOT NULL,
    expiryDateMillis INTEGER NOT NULL,
    amount INTEGER NOT NULL,
    totalAmount INTEGER NOT NULL
);

selectAll:
SELECT * FROM FinanceEntity;

insertTransaction:
INSERT INTO FinanceEntity(name, category, expiryDateMillis, amount,totalAmount)
VALUES ( ?, ?, ?,?,?);

deleteTransactionById:
DELETE FROM FinanceEntity WHERE id = ?;
