CREATE TABLE FinanceEntity (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    category TEXT NOT NULL,
    expiryDateMillis INTEGER NOT NULL,
    price INTEGER NOT NULL
);

selectAll:
SELECT * FROM FinanceEntity;

insertTransaction:
INSERT INTO FinanceEntity(id,name, category, expiryDateMillis, price)
VALUES (?, ?, ?, ?,?);

deleteTransactionById:
DELETE FROM FinanceEntity WHERE id = ?;
